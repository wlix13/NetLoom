{% import "_base/_macros.j2" as macros -%}
{{ macros.comment("Network configuration for " ~ iface.name ~ " on " ~ node.name) }}
[Match]
Name={{ iface.name }}

{% if iface.mtu -%}
[Link]
MTUBytes={{ iface.mtu }}
{% endif -%}

[Network]
{% if iface.dhcp -%}
DHCP=yes
{% else -%}
LinkLocalAddressing=no
{% if iface.ip -%}
Address={{ iface.ip }}
{% endif -%}
{% if iface.gateway -%}
Gateway={{ iface.gateway }}
{% endif -%}
{% endif %}
