{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://asvk.topology/schema/3.0",
  "title": "ASVK Structured Topology",
  "type": "object",
  "required": ["meta", "networks", "nodes"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "ip_forwarding": { "type": "boolean", "default": false },
        "sysctl": {
          "type": "object",
          "description": "Global kernel parameters (e.g. net.ipv4.ip_forward=1)"
        },
        "vbox": {
          "type": "object",
          "description": "VirtualBox-specific VM settings.",
          "properties": {
            "paravirt_provider": {
              "type": "string",
              "enum": ["default", "legacy", "minimal", "hyperv", "kvm", "none"],
              "default": "kvm",
              "description": "Paravirtualization provider."
            },
            "chipset": {
              "type": "string",
              "enum": ["piix3", "ich9"],
              "default": "ich9",
              "description": "Chipset type."
            },
            "ioapic": {
              "type": "boolean",
              "default": true,
              "description": "Enable I/O APIC."
            },
            "hpet": {
              "type": "boolean",
              "default": true,
              "description": "Enable High Precision Event Timer."
            }
          }
        }
      }
    },
    "networks": {
      "type": "array",
      "description": "L2 networks, which are mapped to VirtualBox internal networks.",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name of the L2 network."
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["router", "switch", "host"],
            "default": "host"
          },
          "sysctl": {
            "type": "object",
            "description": "Node-specific kernel parameters."
          },
          "interfaces": {
            "type": "object",
            "description": "Named interfaces: physical NICs connected to networks, or OS-only interfaces (loopback).",
            "patternProperties": {
              "^[a-zA-Z0-9_.-]+$": {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": ["physical", "loopback"],
                    "default": "physical",
                    "description": "'physical' gets a VirtualBox NIC when 'network' is set. 'loopback' is OS-only: no NIC, no MAC, skips .link template."
                  },
                  "index": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 36,
                    "description": "VirtualBox adapter slot (1-36). Auto-assigned if omitted."
                  },
                  "network": {
                    "type": "string",
                    "description": "The name of the L2 network this interface is connected to. Required for 'physical'; forbidden for 'loopback'."
                  },
                  "ip": {
                    "type": "string",
                    "description": "CIDR (e.g. 10.0.12.1/24)"
                  },
                  "gateway": { "type": "string" },
                  "dhcp": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable DHCP on this interface."
                  },
                  "mtu": {
                    "type": "integer",
                    "description": "MTU override. Uses OS default if omitted."
                  },
                  "configured": {
                    "type": "boolean",
                    "default": true,
                    "description": "If false, config file is NOT generated."
                  },
                  "mac": {
                    "type": "string",
                    "description": "Static MAC address (e.g. 02:00:00:00:00:01). Auto-generated deterministically if omitted."
                  },
                  "proxy_arp": {
                    "type": "array",
                    "description": "IP addresses for which this interface will proxy ARP replies. Enables IPv4ProxyARP on the interface and registers each address in the neighbour proxy.",
                    "items": { "type": "string" }
                  }
                },
                "allOf": [
                  {
                    "if": { "properties": { "kind": { "const": "loopback" } } },
                    "then": {
                      "not": {
                        "anyOf": [
                          { "required": ["network"] },
                          { "required": ["index"] }
                        ]
                      }
                    }
                  }
                ],
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "vlans": {
            "type": "array",
            "description": "VLAN (802.1Q) interface configurations.",
            "items": {
              "type": "object",
              "required": ["id", "parent"],
              "properties": {
                "id": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 4094,
                  "description": "VLAN ID (1-4094)"
                },
                "parent": {
                  "type": "string",
                  "description": "Parent interface name (e.g., eth1)"
                },
                "name": {
                  "type": "string",
                  "description": "Custom interface name (e.g. 'vlan5'). Defaults to '{parent}.{id}' if omitted."
                },
                "ip": {
                  "type": "string",
                  "description": "CIDR (e.g. 10.0.12.1/24)"
                },
                "gateway": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "tunnels": {
            "type": "array",
            "description": "IP tunnel configurations (IPIP, GRE, SIT).",
            "items": {
              "type": "object",
              "required": ["name", "local", "remote"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Tunnel interface name"
                },
                "type": {
                  "type": "string",
                  "enum": ["ipip", "gre", "sit"],
                  "default": "ipip",
                  "description": "Tunnel type"
                },
                "local": {
                  "type": "string",
                  "description": "Local endpoint IP address"
                },
                "remote": {
                  "type": "string",
                  "description": "Remote endpoint IP address"
                },
                "ip": {
                  "type": "string",
                  "description": "IP address in CIDR notation for the tunnel interface"
                }
              }
            }
          },
          "bridges": {
            "type": "array",
            "description": "Bridge configurations. Each bridge groups interfaces/VLANs into one L2 domain.",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string",
                  "default": "br0",
                  "description": "Bridge interface name."
                },
                "stp": {
                  "type": "boolean",
                  "default": false,
                  "description": "Enable Spanning Tree Protocol."
                },
                "members": {
                  "type": "array",
                  "description": "Interface or VLAN names that are bridge ports. If omitted, all non-loopback interfaces on the node are used.",
                  "items": { "type": "string" }
                },
                "configured": {
                  "type": "boolean",
                  "default": true,
                  "description": "If false, config file is NOT generated."
                }
              }
            }
          },
          "routing": {
            "type": "object",
            "properties": {
              "engine": { "type": "string", "enum": ["bird", "frr", "none"] },
              "router_id": { "type": "string" },
              "static": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "destination": { "type": "string" },
                    "gateway": { "type": "string" }
                  },
                  "required": ["destination", "gateway"],
                  "additionalProperties": false
                }
              },
              "ospf": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "areas": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "default": "0.0.0.0" },
                        "interfaces": {
                          "type": "array",
                          "items": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              },
              "rip": {
                "type": "object",
                "description": "RIP routing configuration.",
                "properties": {
                  "enabled": { "type": "boolean", "default": false },
                  "version": {
                    "type": "integer",
                    "enum": [1, 2],
                    "default": 2,
                    "description": "RIP version (1 or 2)"
                  },
                  "interfaces": {
                    "type": "array",
                    "description": "Interfaces participating in RIP",
                    "items": { "type": "string" }
                  }
                }
              },
              "configured": { "type": "boolean", "default": true }
            }
          },
          "services": {
            "type": "object",
            "properties": {
              "http_server": { "type": "integer" },
              "wireguard": {
                "type": "object",
                "properties": {
                  "private_key": { "type": "string" },
                  "listen_port": { "type": "integer" },
                  "address": { "type": "string" },
                  "peers": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "public_key": { "type": "string" },
                        "allowed_ips": { "type": "string" },
                        "endpoint": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "firewall": {
                "type": "object",
                "properties": {
                  "impl": { "type": "string", "enum": ["nftables"] },
                  "rules": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["action"],
                      "properties": {
                        "action": {
                          "type": "string",
                          "enum": ["accept", "drop", "reject"]
                        },
                        "src": { "type": "string" },
                        "dst": { "type": "string" },
                        "proto": { "type": "string" },
                        "dport": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          },
          "commands": {
            "type": "array",
            "description": "Raw shell commands for edge cases (e.g. ipip tunnels).",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
